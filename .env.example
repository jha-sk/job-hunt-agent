# =============================================================================
# .env.example — Job Hunt Agent
#
# Copy this file to `.env` (which is gitignored), then fill in the real values.
# Every key below has a "How to get it" comment so you don't have to guess.
#
#   PowerShell:   Copy-Item .env.example .env
#   bash:         cp .env.example .env
# =============================================================================


# =============================================================================
# 1. LLM PROVIDER (Phases 3, 4, 7, 8, 10)
# =============================================================================
# This is the BRAIN of the system. Pick ONE provider — anthropic is the
# default and what the master prompt assumes. See README / Phase 1 wrap-up
# for the cost trade-off (Anthropic ≈ $6-25/month after free credit vs.
# Gemini free tier = $0 but lower quality on tailoring).
#
# Sourabh chose Gemini Free at Phase 1 wrap-up. Switch to "anthropic"
# anytime if you want to upgrade to the Hybrid (~$6-10/mo) path.
LLM_PROVIDER=gemini                 # anthropic | gemini

# --- Anthropic ---------------------------------------------------------------
# HOW TO GET: https://console.anthropic.com/settings/keys
#   1. Sign up / log in
#   2. Click "Create Key"
#   3. New accounts get $5 in starter credit (one-time, no auto-recharge)
#   4. Paste the key below (starts with sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Model selection. We default to a hybrid: Haiku for high-volume scoring
# (cheap), Sonnet for the 10 tailored resumes (quality matters). You can
# override either; both must be valid model IDs from console.anthropic.com.
ANTHROPIC_MODEL_SCORER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_TAILOR=claude-sonnet-4-6
ANTHROPIC_MODEL_QUIZ=claude-sonnet-4-6
ANTHROPIC_MODEL_GMAIL=claude-haiku-4-5-20251001

# --- Gemini (alternative free-tier provider) ---------------------------------
# Leave blank unless LLM_PROVIDER=gemini.
# HOW TO GET: https://aistudio.google.com/app/apikey
#   1. Sign in with your Google account
#   2. Click "Create API key"
#   3. Free tier: 1500 requests/day on gemini-2.5-flash (more than enough)
GEMINI_API_KEY=
GEMINI_MODEL_SCORER=gemini-2.5-flash
GEMINI_MODEL_TAILOR=gemini-2.5-flash-lite


# =============================================================================
# 2. GMAIL API (Phase 7 — email classification + Phase 10 daily digest)
# =============================================================================
# We use OAuth2 (free, no Google Workspace required). One-time browser
# consent on first run, then a refresh token is cached locally in token.json.
#
# HOW TO GET CREDENTIALS:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (e.g. "job-hunt-agent")
#   3. Enable "Gmail API" under APIs & Services → Library
#   4. APIs & Services → OAuth consent screen:
#        - User type: External
#        - Add yourself as a Test User (you stay in test mode forever; that's fine)
#        - Scopes: add `gmail.readonly` and `gmail.send`
#   5. APIs & Services → Credentials → Create Credentials → OAuth client ID:
#        - Type: Desktop app
#        - Name: anything (e.g. "job-hunt-cli")
#   6. Download the JSON file. Save it as `credentials.json` in this project root.
#      Phase 7 walks you through the first-run OAuth flow.
#
# The values below are pulled from credentials.json automatically — you
# only need to fill them if you'd rather not have credentials.json on disk.
# Recommended: leave blank, use credentials.json.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Email address the digest is sent TO (and the inbox the watcher reads FROM).
DIGEST_RECIPIENT_EMAIL=codewithsourabhjha@gmail.com


# =============================================================================
# 3. JOB SOURCES (Phase 2)
# =============================================================================
# RemoteOK and Himalayas need NO keys (free public APIs).
# Adzuna and JSearch need free signups — leave blank to skip those sources;
# the fetcher will log "not configured" and continue with the other sources.
#
# --- Adzuna (free 1000 calls/month) ----------------------------------------
# Aggregator. Includes some LinkedIn + Naukri postings depending on country.
# HOW TO GET:
#   1. Sign up at https://developer.adzuna.com/signup (free)
#   2. After signup you get an APP_ID and APP_KEY on the dashboard
#   3. Paste both below
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Country codes to query (comma-separated). 'in' = India, 'gb' = UK,
# 'us' = USA. Each country = separate API call, so keep this short to stay
# under the 1000/mo cap. Default: India + US (~12 calls/day = ~360/mo).
ADZUNA_COUNTRIES=in,us

# --- JSearch via RapidAPI (free 150 calls/month — tight!) -------------------
# Aggregates LinkedIn, Indeed, ZipRecruiter, Glassdoor.
# Free tier is only ~5 calls/day, so we use it sparingly: ONE highest-value
# keyword query per day. Configurable below.
# HOW TO GET:
#   1. Sign up at https://rapidapi.com/auth/sign-up (free)
#   2. Go to https://rapidapi.com/letscrape-6bRgm3GnNRZ/api/jsearch
#   3. Click "Subscribe to Test" → choose the BASIC (free) plan
#   4. Copy your X-RapidAPI-Key from the playground
RAPIDAPI_KEY=
# Single daily query to spend the JSearch budget on. Choose the keyword
# you most want LinkedIn coverage for. Defaults to your highest-leverage
# AI keyword.
JSEARCH_DAILY_QUERY=AI engineer remote


# =============================================================================
# 4. OPTIONAL — GitHub (Phase 11)
# =============================================================================
# Only needed if you push the repo to GitHub and want Actions to run.
# For local-only operation, leave this blank.
# HOW TO GET: https://github.com/settings/tokens (Personal Access Token, classic).
# Scopes needed: `repo` (private) or `public_repo` (public).
GITHUB_TOKEN=


# =============================================================================
# 5. PIPELINE BEHAVIOUR TOGGLES
# =============================================================================
# Override these from config.py defaults without editing code.

# Minimum match score (0-100) to include a job in today's top-10. Defaults
# to 60. Lower means more jobs but lower quality matches.
MIN_MATCH_SCORE=60

# Number of top jobs to tailor resumes for per day. Defaults to 10.
TOP_JOBS_PER_DAY=10

# Days after applying with no response before a job is flagged as "ghosted".
GHOSTED_THRESHOLD_DAYS=14

# Hard daily token cap — if exceeded, the pipeline halts and emails you.
# Set generously; this is a SAFETY brake, not a budget.
DAILY_TOKEN_CAP=500000
